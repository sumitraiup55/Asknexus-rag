# Server
PORT=8000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL
CLIENT_URL=http://localhost:5173


# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads/temp

# Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_LLM_FALLBACK_MODELS=gemini-2.5-flash-lite
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_DELAY_MS=2000

# Qdrant Vector Database
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=asknexus_documents
QDRANT_VECTOR_SIZE=3072

ADMIN_EMAIL=sumitraiup55@gmail.com
SMTP_EMAIL=sumitraiup55@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop

OTP_EXPIRY_MINUTES=10
OTP_RATE_LIMIT_WINDOW_MINUTES=10
OTP_MAX_REQUESTS_PER_WINDOW=5